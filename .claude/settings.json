{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/pre-pr-precheck-node.js\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/pre-pr-via-release-node.js\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/review-before-merge-node.js\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
